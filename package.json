{
  "name": "toddum2",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write \"**/*.{js,css,html,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,css,html,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint js tests scripts --max-warnings=50",
    "lint:strict": "eslint js tests scripts --max-warnings=0",
    "check:unused": "node scripts/check-unused-files.mjs",
    "check:sizes": "node scripts/check-large-files.mjs",
    "check:css": "node scripts/check-css-audit.mjs",
    "check": "npm run format:check && npm test && npm run lint && npm run check:unused && npm run check:sizes && npm run check:css"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "vitest": "latest"
  }
}
