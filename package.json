{
  "name": "toddum2",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write \"**/*.{js,css,html,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,css,html,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:unused": "node scripts/check-unused-files.mjs",
    "check:sizes": "node scripts/check-large-files.mjs",
    "check": "npm run format:check && npm test && npm run check:unused && npm run check:sizes"
  },
  "devDependencies": {
    "prettier": "latest",
    "vitest": "latest"
  }
}
