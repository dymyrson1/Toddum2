/* ===== DETAILED LOG PAGE ===== */

.logg-detaljert-view,
.pro-log-page,
#loggDetaljertTab {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.logg-header,
.pro-log-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  padding: 18px 20px;
  border: 1px solid var(--border);
  border-radius: 20px;
  background: var(--card);
  box-shadow: var(--soft-shadow);
}

.logg-header-main,
.pro-log-header-main {
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-width: 0;
}

.logg-header h2,
.pro-log-header h2 {
  margin: 0;
  font-size: 2rem;
  line-height: 1.15;
  letter-spacing: -0.02em;
}

.logg-header p,
.pro-log-header p,
.logg-subtitle,
.pro-log-subtitle {
  margin: 0;
  color: var(--muted);
  font-size: 0.98rem;
}

.logg-header-meta,
.pro-log-header-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.logg-meta-pill,
.pro-log-meta-pill,
.log-count-pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 34px;
  padding: 0 12px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: rgba(37, 99, 235, 0.06);
  color: var(--text);
  font-size: 0.92rem;
  font-weight: 600;
}

.logg-header-actions,
.pro-log-header-actions {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

/* ===== BUTTONS ===== */

.danger-btn,
.minimal-danger-btn {
  appearance: none;
  border: 1px solid rgba(220, 38, 38, 0.2);
  background: rgba(220, 38, 38, 0.08);
  color: #b91c1c;
  border-radius: 12px;
  cursor: pointer;
  font: inherit;
  font-weight: 700;
  transition:
    background 0.18s ease,
    border-color 0.18s ease,
    transform 0.18s ease,
    box-shadow 0.18s ease;
}

.danger-btn {
  min-height: 42px;
  padding: 0 14px;
}

.minimal-danger-btn {
  min-height: 34px;
  padding: 0 12px;
  font-size: 0.92rem;
}

.danger-btn:hover,
.minimal-danger-btn:hover {
  background: rgba(220, 38, 38, 0.14);
  border-color: rgba(220, 38, 38, 0.3);
  transform: translateY(-1px);
}

.danger-btn:disabled,
.minimal-danger-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}

/* ===== CARD / TABLE WRAPPER ===== */

.logg-card,
.pro-log-card {
  border: 1px solid var(--border);
  border-radius: 20px;
  background: var(--card);
  box-shadow: var(--soft-shadow);
  overflow: hidden;
}

.logg-table-section,
.pro-log-table-section {
  border: 1px solid var(--border);
  border-radius: 20px;
  background: var(--card);
  box-shadow: var(--soft-shadow);
  overflow: hidden;
}

.logg-table-top,
.pro-log-table-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 16px 18px;
  border-bottom: 1px solid var(--border);
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.35) 0%,
    rgba(255, 255, 255, 0) 100%
  );
}

.logg-table-top h3,
.pro-log-table-top h3 {
  margin: 0;
  font-size: 1rem;
}

.logg-table-top p,
.pro-log-table-top p {
  margin: 0;
  font-size: 0.92rem;
  color: var(--muted);
}

.logg-table-wrap,
.pro-log-table-wrap {
  overflow-x: auto;
  overflow-y: visible;
}

.logg-table,
.pro-log-table {
  width: 100%;
  min-width: 1160px;
  border-collapse: collapse;
  table-layout: fixed;
}

.logg-table thead th,
.pro-log-table thead th {
  position: sticky;
  top: 0;
  z-index: 2;
  padding: 14px 16px;
  text-align: left;
  font-size: 0.82rem;
  font-weight: 800;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--muted);
  background: var(--header);
  border-bottom: 1px solid var(--border);
}

.logg-table tbody tr,
.pro-log-table tbody tr {
  transition: background 0.18s ease;
}

.logg-table tbody tr:nth-child(even),
.pro-log-table tbody tr:nth-child(even) {
  background: rgba(15, 23, 42, 0.018);
}

.logg-table tbody tr:hover,
.pro-log-table tbody tr:hover {
  background: rgba(37, 99, 235, 0.05);
}

.logg-table td,
.pro-log-table td {
  padding: 14px 16px;
  border-bottom: 1px solid var(--border);
  vertical-align: top;
  line-height: 1.45;
  font-size: 0.95rem;
  color: var(--text);
  word-break: break-word;
}

.logg-table tbody tr:last-child td,
.pro-log-table tbody tr:last-child td {
  border-bottom: none;
}

/* ===== COLUMN WIDTHS ===== */

.logg-table th:nth-child(1),
.logg-table td:nth-child(1),
.pro-log-table th:nth-child(1),
.pro-log-table td:nth-child(1) {
  width: 120px;
}

.logg-table th:nth-child(2),
.logg-table td:nth-child(2),
.pro-log-table th:nth-child(2),
.pro-log-table td:nth-child(2) {
  width: 90px;
}

.logg-table th:nth-child(3),
.logg-table td:nth-child(3),
.pro-log-table th:nth-child(3),
.pro-log-table td:nth-child(3) {
  width: 120px;
}

.logg-table th:nth-child(4),
.logg-table td:nth-child(4),
.pro-log-table th:nth-child(4),
.pro-log-table td:nth-child(4) {
  width: 180px;
}

.logg-table th:nth-child(5),
.logg-table td:nth-child(5),
.pro-log-table th:nth-child(5),
.pro-log-table td:nth-child(5) {
  width: 280px;
}

.logg-table th:nth-child(6),
.logg-table td:nth-child(6),
.pro-log-table th:nth-child(6),
.pro-log-table td:nth-child(6) {
  width: 220px;
}

.logg-table th:nth-child(7),
.logg-table td:nth-child(7),
.pro-log-table th:nth-child(7),
.pro-log-table td:nth-child(7) {
  width: 220px;
}

/* ===== CELL HELPERS ===== */

.log-cell-primary {
  font-weight: 700;
}

.log-cell-muted {
  color: var(--muted);
}

.log-cell-empty,
.log-empty-value {
  color: var(--muted);
  font-style: italic;
}

.log-cell-before,
.log-cell-after {
  white-space: pre-wrap;
  overflow-wrap: anywhere;
}

.log-change-block {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.log-object-main {
  font-weight: 700;
}

.log-object-sub {
  color: var(--muted);
  font-size: 0.9rem;
}

.log-time {
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}

.log-week {
  font-weight: 700;
  white-space: nowrap;
}

/* ===== BADGES ===== */

.pro-log-badge,
.log-type-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  min-height: 28px;
  padding: 0 10px;
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.02em;
  border: 1px solid transparent;
  white-space: nowrap;
}

.pro-log-badge.is-add,
.log-type-badge.is-add {
  background: rgba(22, 163, 74, 0.12);
  color: #15803d;
  border-color: rgba(22, 163, 74, 0.2);
}

.pro-log-badge.is-update,
.log-type-badge.is-update {
  background: rgba(37, 99, 235, 0.12);
  color: #1d4ed8;
  border-color: rgba(37, 99, 235, 0.2);
}

.pro-log-badge.is-delete,
.log-type-badge.is-delete {
  background: rgba(220, 38, 38, 0.12);
  color: #b91c1c;
  border-color: rgba(220, 38, 38, 0.2);
}

.pro-log-badge.is-neutral,
.log-type-badge.is-neutral {
  background: rgba(100, 116, 139, 0.14);
  color: #475569;
  border-color: rgba(100, 116, 139, 0.24);
}

/* ===== EMPTY STATE ===== */

.log-empty,
.pro-log-empty {
  padding: 42px 20px;
  text-align: center;
  color: var(--muted);
}

.log-empty strong,
.pro-log-empty strong {
  display: block;
  margin-bottom: 6px;
  color: var(--text);
  font-size: 1.02rem;
}

/* ===== PAGINATION ===== */

.log-pagination {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  flex-wrap: wrap;
  padding: 16px 18px;
  border-top: 1px solid var(--border);
  background: rgba(15, 23, 42, 0.015);
}

.log-pagination-info {
  color: var(--muted);
  font-size: 0.93rem;
}

.log-pagination-nav {
  display: flex;
  align-items: center;
  gap: 10px;
}

.log-page-btn {
  appearance: none;
  min-width: 40px;
  height: 40px;
  border: 1px solid var(--border);
  border-radius: 12px;
  background: var(--card);
  color: var(--text);
  cursor: pointer;
  font: inherit;
  font-weight: 700;
  transition:
    background 0.18s ease,
    border-color 0.18s ease,
    transform 0.18s ease;
}

.log-page-btn:hover {
  background: rgba(37, 99, 235, 0.06);
  border-color: rgba(37, 99, 235, 0.25);
  transform: translateY(-1px);
}

.log-page-btn:disabled {
  opacity: 0.45;
  cursor: not-allowed;
  transform: none;
}

.log-page-indicator {
  min-width: 92px;
  text-align: center;
  color: var(--muted);
  font-weight: 700;
}

/* ===== LEGACY / EXTRA SUPPORT ===== */

.logg-item-main {
  font-weight: 700;
}

.logg-meta {
  color: var(--muted);
  font-size: 0.92rem;
}

.logg-details {
  color: var(--text);
  white-space: pre-wrap;
}

.pro-log-table td code,
.logg-table td code {
  font-family:
    ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono',
    monospace;
  font-size: 0.88em;
  padding: 2px 6px;
  border-radius: 8px;
  background: rgba(15, 23, 42, 0.06);
}

/* ===== DARK THEME ===== */

html[data-theme='dark'] .logg-header,
html[data-theme='dark'] .pro-log-header,
html[data-theme='dark'] .logg-table-section,
html[data-theme='dark'] .pro-log-table-section,
html[data-theme='dark'] .logg-card,
html[data-theme='dark'] .pro-log-card {
  background: var(--card);
  border-color: var(--border);
}

html[data-theme='dark'] .logg-table thead th,
html[data-theme='dark'] .pro-log-table thead th {
  background: rgba(255, 255, 255, 0.04);
}

html[data-theme='dark'] .logg-table tbody tr:nth-child(even),
html[data-theme='dark'] .pro-log-table tbody tr:nth-child(even) {
  background: rgba(255, 255, 255, 0.015);
}

html[data-theme='dark'] .logg-table tbody tr:hover,
html[data-theme='dark'] .pro-log-table tbody tr:hover {
  background: rgba(96, 165, 250, 0.08);
}

html[data-theme='dark'] .log-pagination {
  background: rgba(255, 255, 255, 0.02);
}

html[data-theme='dark'] .danger-btn,
html[data-theme='dark'] .minimal-danger-btn {
  background: rgba(248, 113, 113, 0.12);
  color: #fca5a5;
  border-color: rgba(248, 113, 113, 0.22);
}

html[data-theme='dark'] .danger-btn:hover,
html[data-theme='dark'] .minimal-danger-btn:hover {
  background: rgba(248, 113, 113, 0.18);
}

html[data-theme='dark'] .log-page-btn {
  background: rgba(255, 255, 255, 0.03);
}

html[data-theme='dark'] .log-page-btn:hover {
  background: rgba(96, 165, 250, 0.08);
  border-color: rgba(96, 165, 250, 0.24);
}

html[data-theme='dark'] .logg-table td code,
html[data-theme='dark'] .pro-log-table td code {
  background: rgba(255, 255, 255, 0.06);
}

/* ===== RESPONSIVE ===== */

@media (max-width: 980px) {
  .logg-header,
  .pro-log-header {
    flex-direction: column;
    align-items: stretch;
  }

  .logg-header-actions,
  .pro-log-header-actions {
    width: 100%;
    justify-content: flex-start;
  }

  .logg-table,
  .pro-log-table {
    min-width: 980px;
  }
}

@media (max-width: 640px) {
  .logg-header,
  .pro-log-header {
    padding: 16px;
    border-radius: 16px;
  }

  .logg-header h2,
  .pro-log-header h2 {
    font-size: 1.45rem;
  }

  .logg-table-top,
  .pro-log-table-top,
  .log-pagination {
    padding: 14px;
  }

  .logg-table thead th,
  .pro-log-table thead th,
  .logg-table td,
  .pro-log-table td {
    padding: 12px 12px;
  }

  .logg-table,
  .pro-log-table {
    min-width: 900px;
  }
}